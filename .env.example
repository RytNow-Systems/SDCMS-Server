# Server
PORT=5000
# Database
DB_HOST=
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_PORT=3306 # why?

# Optional future configs
JWT_SECRET=
API_BASE_URL=

# Fallback to in-memory mock data (true) or use live MySQL stored procedures (false)
USE_MOCK_DB=true

# Auto-dispatch on COURIER scan:
#   true  → COURIER scan fires AWB Link + Dispatch atomically, then sends notification
#   false → COURIER scan stops at AWB Linked; OPERATOR/ADMIN dispatch manually via POST /parcels/dispatch
#   OPERATOR/ADMIN are always manual regardless of this flag
AUTO_DISPATCH_ON_SCAN=false