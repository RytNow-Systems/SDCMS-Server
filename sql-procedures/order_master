prc_order_master_search:

CREATE DEFINER=`user`@`%` PROCEDURE `prc_order_master_search`(pPkOrderId int(11), pFkPartyId int(11), pFkCourierId int(11), pFkOrderStatusId int(11))
BEGIN
/***************************************************
Author:		SDCMS
Module Name	: Transaction
File name in solution	: Transaction/order_master.aspx
UserControl/Field Name : model-order
Input Parameter	: pPkOrderId, pFkPartyId, pFkCourierId, pFkOrderStatusId
Output Parameter : PkOrderId, OrderCode, FkPartyId, SenderMobile, SenderAddress, FkCourierId, FkOrderStatusId, OrderDate, ExpectedDeliveryDate, TotalAmount, CreatedDate, CreatedBy, UpdatedDate, UpdatedBy, CreateUserName, UpdateUserName, SenderName, SenderPhone, CourierName, OrderStatusName, IsActive
Description : used to display list of order details as per given constraints
****************************************************/
		SELECT  order_master.PkOrderId, order_master.OrderCode, order_master.FkPartyId, order_master.SenderMobile, order_master.SenderAddress, order_master.FkCourierId, order_master.FkOrderStatusId, order_master.OrderDate, order_master.ExpectedDeliveryDate, order_master.TotalAmount,
						 order_master.CreatedDate, order_master.CreatedBy, order_master.UpdatedDate, order_master.UpdatedBy,
					IFNULL(CretedUser.FullName,'') as CreateUserName, IFNULL(UpdatedUser.FullName,'') as UpdateUserName,
					IFNULL(party_master.CustomerName,'') as SenderName, IFNULL(party_master.PhoneNo,'') as SenderPhone,
					IFNULL(courier_partner_master.CourierName,'') as CourierName,
					IFNULL(order_status.LuDetails,'') as OrderStatusName,
                    (CASE WHEN order_master.IsActive = 0 THEN 'InActive' ELSE 'Active' END) AS IsActive
		FROM    order_master
			LEFT JOIN party_master ON party_master.PkPartyId = order_master.FkPartyId
			LEFT JOIN courier_partner_master ON courier_partner_master.CourierId = order_master.FkCourierId
			LEFT JOIN lu_details order_status ON order_status.LuDetailsId = order_master.FkOrderStatusId
			LEFT JOIN employee_master CretedUser ON CretedUser.EmployeeCode = order_master.CreatedBy
			LEFT JOIN employee_master UpdatedUser ON UpdatedUser.EmployeeCode = order_master.UpdatedBy
		WHERE order_master.PkOrderId = CASE WHEN pPkOrderId = 0 THEN order_master.PkOrderId ELSE pPkOrderId END AND
					order_master.FkPartyId = CASE WHEN pFkPartyId = 0 THEN order_master.FkPartyId ELSE pFkPartyId END AND
					order_master.FkCourierId = CASE WHEN pFkCourierId = 0 THEN order_master.FkCourierId ELSE pFkCourierId END AND
					order_master.FkOrderStatusId = CASE WHEN pFkOrderStatusId = 0 THEN order_master.FkOrderStatusId ELSE pFkOrderStatusId END
		ORDER BY order_master.PkOrderId DESC;

END

