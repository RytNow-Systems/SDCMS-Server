prc_order_master_get:

CREATE DEFINER=`user`@`%` PROCEDURE `prc_order_master_get`(pAction INT, pPkOrderId INT)
BEGIN
IF pAction = 0 THEN
		SELECT order_master.PkOrderId, order_master.OrderCode, order_master.FkSenderId, party_details.PkPartyDetailsId,party_details.EmailId,party_details.Address,party_details.city,party_details.State, party_details.Pincode,party_details.Country, order_master.OrderDate, order_master.ExpectedDeliveryDate, order_master.TotalAmount,
				order_master.CreatedDate, order_master.CreatedBy, IFNULL(CreatedUser.FullName,'') as CreateUserName,
				order_master.UpdatedDate, order_master.UpdatedBy, IFNULL(UpdatedUser.FullName,'') as UpdatedUserName,
                COUNT(DISTINCT parcel_details.PkParcelDetailsId) AS TotalParcels,
				(CASE WHEN order_master.IsActive = 0 THEN 'InActive' ELSE 'Active' END) AS IsActive
		FROM order_master
			LEFT JOIN employee_master CreatedUser ON CreatedUser.EmployeeCode = order_master.CreatedBy
			LEFT JOIN employee_master UpdatedUser ON UpdatedUser.EmployeeCode = order_master.UpdatedBy
            LEFT JOIN receiver_details ON receiver_details.FkOrderId = order_master.PkOrderId
            left join party_details on order_master.FkPartyDetailsId = party_details.PkPartyDetailsId
			LEFT JOIN parcel_details ON parcel_details.FkReceiverDetailsId = receiver_details.PkReceiverDetailsId
		GROUP BY order_master.PkOrderId, order_master.OrderCode, order_master.FkSenderId,party_details.PkPartyDetailsId,party_details.EmailId,party_details.Address,party_details.city,party_details.State, party_details.Pincode,party_details.Country, order_master.OrderDate, order_master.ExpectedDeliveryDate, order_master.TotalAmount, order_master.CreatedDate, order_master.CreatedBy, CreatedUser.FullName, order_master.UpdatedDate, order_master.UpdatedBy, UpdatedUser.FullName, order_master.IsActive
		ORDER BY order_master.PkOrderId DESC;
END IF;

IF pAction = 1 THEN
		SELECT order_master.PkOrderId, order_master.OrderCode, order_master.FkSenderId,party_details.PkPartyDetailsId,party_details.EmailId,party_details.Address,party_details.city,party_details.State, party_details.Pincode,party_details.Country, order_master.OrderDate, order_master.ExpectedDeliveryDate, order_master.TotalAmount,
				order_master.CreatedDate, order_master.CreatedBy, IFNULL(CreatedUser.FullName,'') as CreateUserName,
				order_master.UpdatedDate, order_master.UpdatedBy, IFNULL(UpdatedUser.FullName,'') as UpdatedUserName,
				(CASE WHEN order_master.IsActive = 0 THEN 'InActive' ELSE 'Active' END) AS IsActive
		FROM order_master
			LEFT JOIN employee_master CreatedUser ON CreatedUser.EmployeeCode = order_master.CreatedBy
			LEFT JOIN employee_master UpdatedUser ON UpdatedUser.EmployeeCode = order_master.UpdatedBy
            LEFT JOIN receiver_details ON receiver_details.FkOrderId = order_master.PkOrderId
            left join party_details on order_master.FkPartyDetailsId = party_details.PkPartyDetailsId
		WHERE order_master.PkOrderId = pPkOrderId
		ORDER BY order_master.PkOrderId DESC;
END IF;
END

