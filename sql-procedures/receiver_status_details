prc_receiver_status_details_set:

CREATE DEFINER=`user`@`%` PROCEDURE `prc_receiver_status_details_set`(pFkParcelDetailsId INT, pFkReceiverDetailsId INT, pActionType VARCHAR(50), pAWBNumber VARCHAR(100), pCreatedBy INT)
BEGIN
    INSERT INTO receiver_status_details (FkParcelDetailsId, FkReceiverDetailsId, ActionType, AWBNumber, CreatedDate, CreatedBy)
    VALUES (pFkParcelDetailsId, pFkReceiverDetailsId, pActionType, pAWBNumber, NOW(), pCreatedBy);
END
