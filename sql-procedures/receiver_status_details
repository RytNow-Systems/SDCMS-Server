prc_receiver_status_details_get:

CREATE DEFINER=`user`@`%` PROCEDURE `prc_receiver_status_details_get`(pAction INT, pFkParcelDetailsId INT)
BEGIN
    IF pAction = 0 THEN
        SELECT PkReceiverStatusDetailsId, FkParcelDetailsId, FkReceiverDetailsId, FkOrderStatusId, ActionType, AWBNumber, PreviousStatus, CreatedDate, CreatedBy
        FROM receiver_status_details
        ORDER BY CreatedDate DESC;
    END IF;
    IF pAction = 1 THEN
        SELECT PkReceiverStatusDetailsId, FkParcelDetailsId, ActionType, AWBNumber, CreatedDate
        FROM receiver_status_details
        WHERE FkParcelDetailsId = pFkParcelDetailsId
        ORDER BY CreatedDate DESC;
    END IF;
END

