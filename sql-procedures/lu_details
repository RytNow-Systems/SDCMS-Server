Table: lu_details

Columns:
	LuDetailsId	int(11) AI PK
	LuDetails	varchar(50)
	LuDetails_1	varchar(50)
	LuDetails_2	varchar(50)
	LuDetails_3	varchar(50)
	LuMasterId	int(11)
	IsActive	int(11)

---
prc_lu_details_get:

CREATE DEFINER=`user`@`%` PROCEDURE `prc_lu_details_get`(pAction INT, pLookUpId INT)
BEGIN
IF pAction = 0 THEN
		SELECT lu_details.LuDetailsId, lu_details.LuMasterId, lu_details.LuDetails, lu_details.LuDetails_1, lu_details.LuDetails_2, lu_details.LuDetails_3, IFNULL(lu_master.LuMaster,'') as LuMasterName,
					(CASE WHEN lu_details.IsActive = 0 THEN 'InActive' ELSE 'Active' END) AS IsActive
		FROM lu_details
			LEFT JOIN lu_master ON lu_master.LuMasterId = lu_details.LuMasterId
		ORDER BY lu_details.LuMasterId, lu_details.LuDetailsId;
	END IF;
	IF pAction = 1 THEN
		SELECT lu_details.LuDetailsId, lu_details.LuMasterId, lu_details.LuDetails, lu_details.LuDetails_1, lu_details.LuDetails_2, lu_details.LuDetails_3, IFNULL(lu_master.LuMaster,'') as LuMasterName,
					(CASE WHEN lu_details.IsActive = 0 THEN 'InActive' ELSE 'Active' END) AS IsActive
		FROM lu_details
			LEFT JOIN lu_master ON lu_master.LuMasterId = lu_details.LuMasterId
		WHERE lu_details.LuDetailsId = pLookUpId
		ORDER BY lu_details.LuMasterId, lu_details.LuDetailsId;
	END IF;
END

