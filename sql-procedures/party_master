CREATE DEFINER=`user`@`%` PROCEDURE `prc_check_duplicate_Party_master`(pPkPartyId INT, pPhoneNo VARCHAR(20), pEmailId varchar(100))
BEGIN
	IF pPkPartyId = 0 THEN
		SELECT COUNT(*) AS DataCount FROM party_master WHERE PhoneNo = pPhoneNo and EmailId = pEmailId AND IsActive = 1;
	END IF;

	IF pPkPartyId > 0 THEN
		SELECT COUNT(*) AS DataCount FROM party_master WHERE PhoneNo = pPhoneNo and EmailId = pEmailId AND IsActive = 1 AND PkPartyId <> pPkPartyId;
	END IF;
END
