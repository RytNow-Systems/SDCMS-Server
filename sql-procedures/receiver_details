prc_receiver_details_search:

CREATE DEFINER=`user`@`%` PROCEDURE `prc_receiver_details_search`(pPkReceiverDetailsId int(11), pFkOrderId int(11))
BEGIN
/***************************************************
Author:		SDCMS
Module Name	: Transaction
File name in solution	: Transaction/receiver_details.aspx
UserControl/Field Name : model-receiver
Input Parameter	: pPkReceiverDetailsId, pFkOrderId
Output Parameter : PkReceiverDetailsId, FkOrderId, FkReceiverId, ReceiverName, ReceiverPhone, ReceiverEmail, AddressLine1, AddressLine2, City, State, Pincode, Country, OrderCode, ReceiverPartyName, ReceiverPartyPhone, IsActive
Description : used to display list of receiver details for an order as per given constraints
****************************************************/
		SELECT  receiver_details.PkReceiverDetailsId, receiver_details.FkOrderId, receiver_details.FkReceiverId, receiver_details.ReceiverName, receiver_details.ReceiverPhone, receiver_details.ReceiverEmail,
						 receiver_details.AddressLine1, receiver_details.AddressLine2, receiver_details.City, receiver_details.State, receiver_details.Pincode, receiver_details.Country,
					IFNULL(order_master.OrderCode,'') as OrderCode,
					IFNULL(party_master.CustomerName,'') as ReceiverPartyName, IFNULL(party_master.PhoneNo,'') as ReceiverPartyPhone,
                    (CASE WHEN receiver_details.IsActive = 0 THEN 'InActive' ELSE 'Active' END) AS IsActive
		FROM    receiver_details
			LEFT JOIN order_master ON order_master.PkOrderId = receiver_details.FkOrderId
			LEFT JOIN party_master ON party_master.PkPartyId = receiver_details.FkReceiverId
		WHERE receiver_details.PkReceiverDetailsId = CASE WHEN pPkReceiverDetailsId = 0 THEN receiver_details.PkReceiverDetailsId ELSE pPkReceiverDetailsId END AND
					receiver_details.FkOrderId = CASE WHEN pFkOrderId = 0 THEN receiver_details.FkOrderId ELSE pFkOrderId END
		ORDER BY receiver_details.PkReceiverDetailsId;

END

