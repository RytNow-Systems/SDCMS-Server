CREATE DEFINER=`user`@`%` PROCEDURE `prc_receiver_details_get`(pAction INT, pLookUpId INT)
BEGIN
IF pAction = 0 THEN
		SELECT receiver_details.PkReceiverDetailsId, receiver_details.FkOrderId, receiver_details.FkReceiverId, party_details.PkPartyDetailsId,receiver_details.ReceiverName, receiver_details.ReceiverPhone, receiver_details.ReceiverEmail, /*receiver_details.Address, receiver_details.City, receiver_details.State, receiver_details.Pincode, receiver_details.Country,*/party_details.Address,party_details.City,party_details.State,party_details.Pincode,party_details.Country, IFNULL(order_master.OrderCode,'') as OrderCode, IFNULL(party_master.CustomerName,'') as ReceiverPartyName, IFNULL(party_master.PhoneNo,'') as ReceiverPartyPhone,
					(CASE WHEN receiver_details.IsActive = 0 THEN 'InActive' ELSE 'Active' END) AS IsActive
		FROM receiver_details
			LEFT JOIN order_master ON order_master.PkOrderId = receiver_details.FkOrderId
			LEFT JOIN party_master ON party_master.PkPartyId = receiver_details.FkReceiverId
            LEFT JOIN party_details ON receiver_details.FkPartyDetailsId = party_details.PkPartyDetailsId
		ORDER BY receiver_details.PkReceiverDetailsId;
	END IF;
	IF pAction = 1 THEN
		SELECT receiver_details.PkReceiverDetailsId, receiver_details.FkOrderId, receiver_details.FkReceiverId, party_details.PkPartyDetailsId,receiver_details.ReceiverName, receiver_details.ReceiverPhone, receiver_details.ReceiverEmail, /*receiver_details.Address,receiver_details.City, receiver_details.State, receiver_details.Pincode, receiver_details.Country,*/party_details.Address,party_details.City,party_details.State,party_details.Pincode,party_details.Country, IFNULL(order_master.OrderCode,'') as OrderCode, IFNULL(party_master.CustomerName,'') as ReceiverPartyName, IFNULL(party_master.PhoneNo,'') as ReceiverPartyPhone,
					(CASE WHEN receiver_details.IsActive = 0 THEN 'InActive' ELSE 'Active' END) AS IsActive
		FROM receiver_details
			LEFT JOIN order_master ON order_master.PkOrderId = receiver_details.FkOrderId
			LEFT JOIN party_master ON party_master.PkPartyId = receiver_details.FkReceiverId
            LEFT JOIN party_details ON receiver_details.FkPartyDetailsId = party_details.PkPartyDetailsId
		WHERE receiver_details.PkReceiverDetailsId = pLookUpId
		ORDER BY receiver_details.PkReceiverDetailsId;
	END IF;
END

