CREATE DEFINER=`user`@`%` PROCEDURE `prc_product_color_matrix_set`(pPkProductColorId INT, pFkProductId INT, pFkLuColorId INT, pMaterialRate DECIMAL(10,2), pSize VARCHAR(50), pCreatedBy INT, pIsActive INT)
BEGIN
/***************************************************
Author:		Aditya Mulay
Module Name	:master
Input Parameter	: pPkProductColorId, pFkProductId, pFkLuColorId, pMaterialRate, pSize, pCreatedBy, pIsActive
Output Parameter : product color matrix details
Description : used to insert and update product color, size, and material rate mapping details
****************************************************/

DECLARE pProdColorId INT;

	IF pPkProductColorId = 0 THEN
		INSERT INTO product_color_matrix (FkProductId, FkLuColorId, MaterialRate, Size, CreatedBy, CreatedDate, IsActive)
						VALUES (pFkProductId, pFkLuColorId, pMaterialRate, pSize, pCreatedBy, NOW(), pIsActive);

		SELECT LAST_INSERT_ID() INTO pProdColorId;
		SELECT * FROM product_color_matrix WHERE PkProductColorId = pProdColorId;

	ELSE
		UPDATE product_color_matrix SET
		FkProductId = pFkProductId, FkLuColorId = pFkLuColorId, MaterialRate = pMaterialRate, Size = pSize, UpdatedBy = pCreatedBy, UpdatedDate = NOW(), IsActive = pIsActive
		WHERE PkProductColorId = pPkProductColorId;

		SELECT * FROM product_color_matrix WHERE PkProductColorId = pPkProductColorId;

	END IF;

END
