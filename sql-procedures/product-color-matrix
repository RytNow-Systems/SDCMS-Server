	FkProductId	int(11)
	FkLuColorId	int(11)
	MaterialRate	decimal(10,2)
	Size	varchar(50)
	CreatedBy	int(11)
	CreatedDate	datetime
	UpdatedBy	int(11)
	UpdatedDate	datetime
	IsActive	tinyint(1)
---

CREATE DEFINER=`user`@`%` PROCEDURE `prc_product_color_matrix_get`(pAction INT, pPkProductColorId INT)
BEGIN
/***************************************************
Author:		Aditya Mulay
Module Name	:master
Input Parameter	: pAction, pPkProductColorId
Output Parameter : product color matrix details
Description : used to retrieve product color and size mapping details based on action and product color id
****************************************************/

    IF pAction = 0 THEN
        SELECT product_color_matrix.PkProductColorId, product_color_matrix.FkProductId, product_color_matrix.FkLuColorId, product_color_matrix.MaterialRate, product_color_matrix.Size, product_color_matrix.CreatedBy, product_color_matrix.CreatedDate, product_color_matrix.UpdatedBy, product_color_matrix.UpdatedDate, product_color_matrix.IsActive,
               IFNULL(product_master.MaterialName, '') AS MaterialName, IFNULL(lu_color_code.ColorName, '') AS ColorName
        FROM product_color_matrix
        LEFT JOIN product_master ON product_master.PkProductId = product_color_matrix.FkProductId
        LEFT JOIN lu_color_code ON lu_color_code.PkLuColorId = product_color_matrix.FkLuColorId
        where product_color_matrix.IsActive = 1
        -- ORDER BY product_color_matrix.PkProductColorId DESC
        ;
    END IF;

    IF pAction = 1 THEN
        SELECT product_color_matrix.PkProductColorId, product_color_matrix.FkProductId, product_color_matrix.FkLuColorId, product_color_matrix.MaterialRate, product_color_matrix.Size, product_color_matrix.CreatedBy, product_color_matrix.CreatedDate, product_color_matrix.UpdatedBy, product_color_matrix.UpdatedDate, product_color_matrix.IsActive,
               IFNULL(product_master.MaterialName, '') AS MaterialName, IFNULL(lu_color_code.ColorName, '') AS ColorName
        FROM product_color_matrix
        LEFT JOIN product_master ON product_master.PkProductId = product_color_matrix.FkProductId
       LEFT JOIN lu_color_code ON lu_color_code.PkLuColorId = product_color_matrix.FkLuColorId
        WHERE product_color_matrix.PkProductColorId = pPkProductColorId and product_color_matrix.IsActive = 1
		-- ORDER BY product_color_matrix.PkProductColorId
        ;
    END IF;
  /*IF pAction = 2 THEN
        SELECT product_color_matrix.PkProductColorId, product_color_matrix.FkProductId, product_color_matrix.FkLuColorId, product_color_matrix.MaterialRate, product_color_matrix.Size, product_color_matrix.CreatedBy, product_color_matrix.CreatedDate, product_color_matrix.UpdatedBy, product_color_matrix.UpdatedDate, product_color_matrix.IsActive,
               IFNULL(product_master.MaterialName, '') AS MaterialName, IFNULL(lu_color_code.ColorName, '') AS ColorName
        FROM product_color_matrix
        LEFT JOIN product_master ON product_master.PkProductId = product_color_matrix.FkProductId
       LEFT JOIN lu_color_code ON lu_color_code.PkLuColorId = product_color_matrix.FkLuColorId
        WHERE product_color_matrix.FkProductId= pPkProductColorId
		-- ORDER BY product_color_matrix.PkProductColorId
        ; end if;*/
END
