CREATE DEFINER=`user`@`%` PROCEDURE `prc_parcel_details_set`(pPkParcelDetailsId  INT,pTriggerType INT, /* 0=CREATE | 1=PRINT_LABEL | 2=SCAN_LINK_AWB | 3=DISPATCH | 4=DELIVERED | 5=Cancelled*/pFkReceiverDetailsId INT,/* Required only for pTriggerType = 0 (CREATE). Pass NULL for all other triggers.*/ pAWBNumber VARCHAR(100),pFkCourierId INT,pCreatedBy INT)
BEGIN
    DECLARE pReceiverDetailsId INT;

    DECLARE EXIT HANDLER FOR SQLEXCEPTION
    BEGIN
        ROLLBACK;
        RESIGNAL;
    END;
    START TRANSACTION;
    -- -------------------------------------------------------
    -- Trigger 0: CREATE PARCEL (Execution layer — explicit call)
    -- lu_details: 1 = 'Pending'
    -- Called by backend AFTER order + receivers + items are fully defined.
    -- -------------------------------------------------------
    IF pTriggerType = 0 THEN
        INSERT INTO parcel_details (FkReceiverDetailsId, FkCourierId, TrackingNo, QRCode, FkParcelStatusId, ParcelCode,LabelPrintCount, DispatchDate, CreatedDate, CreatedBy) VALUES (pFkReceiverDetailsId, NULL, NULL, UUID(), 1,NULL, NULL, NULL, NOW(), pCreatedBy);
        SET pPkParcelDetailsId = LAST_INSERT_ID();
        UPDATE parcel_details SET ParcelCode = FnGenerateParcelCode() WHERE PkParcelDetailsId = pPkParcelDetailsId;
        SELECT pPkParcelDetailsId AS GeneratedParcelId;
    ELSE
        -- Resolve receiver for audit logging (only needed for update triggers 1-5)
        SELECT FkReceiverDetailsId INTO pReceiverDetailsId
        FROM parcel_details WHERE PkParcelDetailsId = pPkParcelDetailsId;
    -- -------------------------------------------------------
    -- Trigger 1: PRINT LABEL
    -- lu_details: 2 = 'Label Printed'
    -- -------------------------------------------------------
    IF pTriggerType = 1 THEN
        UPDATE parcel_details SET LabelPrintCount  = IFNULL(LabelPrintCount, 0) + 1,FkParcelStatusId = 2
        WHERE PkParcelDetailsId = pPkParcelDetailsId;
        CALL prc_receiver_status_details_set(pPkParcelDetailsId, pReceiverDetailsId, 'PRINT_LABEL', NULL, pCreatedBy);
    -- -------------------------------------------------------
    -- Trigger 2: SCAN & LINK AWB
    -- lu_details: 3 = 'AWB Linked'
    -- -------------------------------------------------------
    ELSEIF pTriggerType = 2 THEN
        UPDATE parcel_details SET TrackingNo= pAWBNumber,FkCourierId= pFkCourierId,FkParcelStatusId = 3
        WHERE PkParcelDetailsId = pPkParcelDetailsId;
        CALL prc_receiver_status_details_set(pPkParcelDetailsId, pReceiverDetailsId, 'AWB_LINK', pAWBNumber, pCreatedBy);
    -- -------------------------------------------------------
    -- Trigger 3: DISPATCH
    -- lu_details: 4 = 'Dispatched'
    -- -------------------------------------------------------
    ELSEIF pTriggerType = 3 THEN
        UPDATE parcel_details SET DispatchDate = NOW(),FkParcelStatusId = 4
        WHERE PkParcelDetailsId = pPkParcelDetailsId;
        CALL prc_receiver_status_details_set(pPkParcelDetailsId, pReceiverDetailsId, 'DISPATCH', pAWBNumber, pCreatedBy);
    -- -------------------------------------------------------
    -- Trigger 4: DELIVERED
    -- lu_details: 5 = 'Delivered'
    -- -------------------------------------------------------
    ELSEIF pTriggerType = 4 THEN
        UPDATE parcel_details SET FkParcelStatusId = 5
        WHERE PkParcelDetailsId = pPkParcelDetailsId;
        CALL prc_receiver_status_details_set(pPkParcelDetailsId, pReceiverDetailsId, 'DELIVERED', NULL, pCreatedBy);
    -- -------------------------------------------------------
    -- Trigger 5: Cancelled
    -- lu_details: 6 = 'Cancelled'
    -- -------------------------------------------------------
    ELSEIF pTriggerType = 5 THEN
        UPDATE parcel_details SET FkParcelStatusId = 6
        WHERE PkParcelDetailsId = pPkParcelDetailsId;
        CALL prc_receiver_status_details_set(pPkParcelDetailsId, pReceiverDetailsId, 'RETURNED', NULL, pCreatedBy);
    END IF; -- close inner trigger (1-5) IF block
    END IF; -- close outer: IF pTriggerType = 0 ... ELSE ... END IF
    COMMIT;
END
