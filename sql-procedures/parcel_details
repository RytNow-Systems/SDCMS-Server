CREATE DEFINER=`user`@`%` PROCEDURE `prc_parcel_details_search`(pPkParcelDetailsId int(11), pFkReceiverDetailsId int(11), pFkCourierId int(11), pFkParcelStatusId int(11))
BEGIN
/***************************************************
Author:		SDCMS
Module Name	: Transaction
File name in solution	: Transaction/parcel_details.aspx
UserControl/Field Name : model-parcel
Input Parameter	: pPkParcelDetailsId, pFkReceiverDetailsId, pFkCourierId, pFkParcelStatusId
Output Parameter : PkParcelDetailsId, FkReceiverDetailsId, FkCourierId, TrackingNo, QRCode, FkParcelStatusId, LabelPrintCount, DispatchDate, CreatedDate, CreatedBy, CreateUserName, ReceiverName, ReceiverPhone, ReceiverCity, ReceiverState, ReceiverPincode, FkOrderId, CourierName, TrackingUrlTemplate, ParcelStatusName, OrderCode
Description : used to display list of parcel details as per given constraints
****************************************************/
		-- FIX 2: receiver_details.ReceiverName/Phone/Address/City/State/Pincode are NULL for Mode A
		-- (sender-to-self) orders — the actual values live in party_master via FkReceiverId.
		-- Added LEFT JOIN party_master and COALESCE to fall back to party fields when receiver_details fields are null/empty.
		-- FIX 3: Added ParcelCode to SELECT so backend search-by-parcelCode (UC-x-y) works.
		SELECT  parcel_details.PkParcelDetailsId, parcel_details.FkReceiverDetailsId, parcel_details.FkCourierId, parcel_details.TrackingNo, parcel_details.QRCode, parcel_details.FkParcelStatusId, parcel_details.ParcelCode, parcel_details.LabelPrintCount, parcel_details.DispatchDate,
						 parcel_details.CreatedDate, parcel_details.CreatedBy,
					IFNULL(CretedUser.FullName,'') as CreateUserName,
					COALESCE(NULLIF(receiver_details.ReceiverName,''), receiver_party.CustomerName, '') as ReceiverName,
					COALESCE(NULLIF(receiver_details.ReceiverPhone,''), receiver_party.PhoneNo, '') as ReceiverPhone,
					COALESCE(NULLIF(receiver_details.Address,''), receiver_party.Address, '') as ReceiverAddress,
					COALESCE(NULLIF(receiver_details.City,''), receiver_party.City, '') as ReceiverCity,
					COALESCE(NULLIF(receiver_details.State,''), receiver_party.State, '') as ReceiverState,
					COALESCE(NULLIF(receiver_details.Pincode,''), receiver_party.Pincode, '') as ReceiverPincode,
					IFNULL(receiver_details.FkOrderId,0) as FkOrderId,
					IFNULL(courier_partner_master.CourierName,'') as CourierName, IFNULL(courier_partner_master.TrackingUrlTemplate,'') as TrackingUrlTemplate,
					IFNULL(parcel_status.LuDetails,'') as ParcelStatusName,
					IFNULL(order_master.OrderCode,'') as OrderCode
		FROM    parcel_details
			LEFT JOIN receiver_details ON receiver_details.PkReceiverDetailsId = parcel_details.FkReceiverDetailsId
			LEFT JOIN party_master receiver_party ON receiver_party.PkPartyId = receiver_details.FkReceiverId
			LEFT JOIN courier_partner_master ON courier_partner_master.CourierId = parcel_details.FkCourierId
			LEFT JOIN lu_details parcel_status ON parcel_status.LuDetailsId = parcel_details.FkParcelStatusId
			LEFT JOIN order_master ON order_master.PkOrderId = receiver_details.FkOrderId
			LEFT JOIN employee_master CretedUser ON CretedUser.EmployeeCode = parcel_details.CreatedBy
		-- FIX 1: CASE-based null-passthrough (col = CASE WHEN 0 THEN col END) fails when col IS NULL
		-- because NULL = NULL evaluates to NULL (not TRUE) in MySQL, silently excluding all pre-dispatch parcels.
		-- Replaced with OR logic: (param = 0 OR col = param) — correctly passes through when param = 0
		-- even for rows where col IS NULL (e.g. FkCourierId before AWB is linked).
		WHERE (pPkParcelDetailsId = 0 OR parcel_details.PkParcelDetailsId = pPkParcelDetailsId) AND
					(pFkReceiverDetailsId = 0 OR parcel_details.FkReceiverDetailsId = pFkReceiverDetailsId) AND
					(pFkCourierId = 0 OR parcel_details.FkCourierId = pFkCourierId) AND
					(pFkParcelStatusId = 0 OR parcel_details.FkParcelStatusId = pFkParcelStatusId)
		ORDER BY parcel_details.PkParcelDetailsId DESC;

END

