FnGenerateParcelCode:

CREATE DEFINER=`user`@`%` FUNCTION `FnGenerateParcelCode`() RETURNS varchar(30) CHARSET utf8
    DETERMINISTIC
BEGIN
    DECLARE pOrderId INT;
    DECLARE pParcelId INT;

    SELECT order_master.PkOrderId, parcel_details.PkParcelDetailsId INTO pOrderId, pParcelId FROM parcel_details
    INNER JOIN receiver_details ON parcel_details.FkReceiverDetailsId = receiver_details.PkReceiverDetailsId
    INNER JOIN order_master ON receiver_details.FkOrderId = order_master.PkOrderId
    ORDER BY parcel_details.PkParcelDetailsId DESC LIMIT 1;

    RETURN CONCAT('UC-', pOrderId, '-', pParcelId);
END

