prc_parcel_details_get:

CREATE DEFINER=`user`@`%` PROCEDURE `prc_parcel_details_get`(pAction INT, pPkParcelDetailsId INT)
BEGIN
    IF pAction = 0 THEN
        SELECT PkParcelDetailsId, FkReceiverDetailsId, FkCourierId, TrackingNo, QRCode, FkParcelStatusId,ParcelCode, LabelPrintCount, DispatchDate, CreatedDate, CreatedBy
        FROM parcel_details
        ORDER BY PkParcelDetailsId DESC;
    END IF;
    IF pAction = 1 THEN
        SELECT PkParcelDetailsId, FkReceiverDetailsId, FkCourierId, TrackingNo, QRCode, FkParcelStatusId,ParcelCode, LabelPrintCount, DispatchDate, CreatedDate, CreatedBy
        FROM parcel_details
        WHERE PkParcelDetailsId = pPkParcelDetailsId;
    END IF;
    IF pAction = 2 THEN -- Label Data
        SELECT parcel_details.PkParcelDetailsId, parcel_details.TrackingNo, parcel_details.QRCode,ParcelCode,
               receiver_details.ReceiverName, receiver_details.ReceiverPhone, receiver_details.Address, receiver_details.City, receiver_details.Pincode
        FROM parcel_details
        INNER JOIN receiver_details ON receiver_details.PkReceiverDetailsId = parcel_details.FkReceiverDetailsId
        WHERE parcel_details.PkParcelDetailsId = pPkParcelDetailsId;
END IF;
END
