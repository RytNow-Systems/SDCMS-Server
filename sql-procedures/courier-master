CREATE DEFINER=`user`@`%` PROCEDURE `prc_courier_partner_master_search`(pCourierId int(11))
BEGIN
/***************************************************
Author:		Aditya Mulay
Module Name	: Admin
File name in solution	: Admin/courier_partner_master.aspx
UserControl/Field Name : model-courier
Input Parameter	: pCourierId
Output Parameter : CourierId, CourierName, TrackingUrlTemplate, IsActive
Description : used to display list of courier partner details as per given constraints
****************************************************/
		SELECT  courier_partner_master.CourierId, courier_partner_master.CourierName, courier_partner_master.PhoneNumber, courier_partner_master.TrackingUrlTemplate,
                    (CASE WHEN courier_partner_master.IsActive = 0 THEN 'InActive' ELSE 'Active' END) AS IsActive
		FROM    courier_partner_master
		WHERE courier_partner_master.CourierId = CASE WHEN pCourierId = 0 THEN courier_partner_master.CourierId ELSE pCourierId END
		ORDER BY courier_partner_master.CourierId;

END

