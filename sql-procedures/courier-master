CREATE DEFINER=`user`@`%` PROCEDURE `prc_courier_partner_master_set`(pCourierId INT, pCourierName VARCHAR(100), pPhoneNumber varchar(20), pTrackingUrlTemplate VARCHAR(255), pCreatedBy INT, pIsActive INT)
BEGIN

DECLARE pId INT;

	IF pCourierId = 0 THEN
		INSERT INTO courier_partner_master (CourierName, PhoneNumber, TrackingUrlTemplate, CreatedDate, CreatedBy, IsActive)
						VALUES (pCourierName, PhoneNumber, pTrackingUrlTemplate, NOW(), pCreatedBy, pIsActive);

		SELECT LAST_INSERT_ID() INTO pId;

	ELSE
		UPDATE courier_partner_master SET
		CourierName = pCourierName, PhoneNumber = pPhoneNumber, TrackingUrlTemplate = pTrackingUrlTemplate, UpdatedDate = NOW(), UpdatedBy = pCreatedBy, IsActive = pIsActive
		WHERE CourierId = pCourierId;

	END IF;

END
