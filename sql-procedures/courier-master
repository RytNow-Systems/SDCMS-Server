CREATE DEFINER=`user`@`%` PROCEDURE `prc_courier_partner_master_get`(pAction INT, pCourierId INT)
BEGIN

    IF pAction = 0 THEN
        SELECT CourierId, CourierName, PhoneNumber, TrackingUrlTemplate, CreatedDate, CreatedBy, UpdatedDate, UpdatedBy,IsActive
        FROM courier_partner_master
        where isactive = 1
        ORDER BY CourierId DESC;
    END IF;

    IF pAction = 1 THEN
        SELECT CourierId, CourierName, PhoneNumber, TrackingUrlTemplate, CreatedDate, CreatedBy, UpdatedDate, UpdatedBy, IsActive
        FROM courier_partner_master
        WHERE CourierId = pCourierId and isactive = 1
		ORDER BY CourierId;
    END IF;

    IF pAction = 2 THEN
        SELECT CourierId, CourierName, PhoneNumber, TrackingUrlTemplate, CreatedDate, CreatedBy, UpdatedDate, UpdatedBy, IsActive
        FROM courier_partner_master
        ORDER BY CourierId DESC;
    END IF;

END
