prc_order_items_search:

CREATE DEFINER=`user`@`%` PROCEDURE `prc_order_items_search`(pPkOrderItemId int(11), pFkReceiverDetailsId int(11), pFkProductId int(11))
BEGIN
/***************************************************
Author:		SDCMS
Module Name	: Transaction
File name in solution	: Transaction/order_items.aspx
UserControl/Field Name : model-orderitems
Input Parameter	: pPkOrderItemId, pFkReceiverDetailsId, pFkProductId
Output Parameter : PkOrderItemId, FkReceiverDetailsId, FkProductId, OutwardQty, FkUnitId, UnitPrice, TransactionDate, CreatedDate, CreatedBy, CreateUserName, MaterialName, MaterialCode, MaterialRate, UnitTitle, UnitCode, ReceiverName, IsActive
Description : used to display list of order line items as per given constraints
****************************************************/
		SELECT  order_items.PkOrderItemId, order_items.FkReceiverDetailsId, order_items.FkProductId, order_items.OutwardQty, order_items.FkUnitId, order_items.UnitPrice, order_items.TransactionDate,
						 order_items.CreatedDate, order_items.CreatedBy,
					IFNULL(CretedUser.FullName,'') as CreateUserName,
					IFNULL(product_master.MaterialName,'') as MaterialName, IFNULL(product_master.MaterialCode,'') as MaterialCode, IFNULL(product_master.MaterialRate,0) as MaterialRate,
					IFNULL(lu_unit.UnitTitle,'') as UnitTitle, IFNULL(lu_unit.UnitCode,'') as UnitCode,
					IFNULL(receiver_details.ReceiverName,'') as ReceiverName,
                    (CASE WHEN order_items.IsActive = 0 THEN 'InActive' ELSE 'Active' END) AS IsActive
		FROM    order_items
			LEFT JOIN product_master ON product_master.PkProductId = order_items.FkProductId
			LEFT JOIN lu_unit ON lu_unit.PkUnitId = order_items.FkUnitId
			LEFT JOIN receiver_details ON receiver_details.PkReceiverDetailsId = order_items.FkReceiverDetailsId
			LEFT JOIN employee_master CretedUser ON CretedUser.EmployeeCode = order_items.CreatedBy
		WHERE order_items.PkOrderItemId = CASE WHEN pPkOrderItemId = 0 THEN order_items.PkOrderItemId ELSE pPkOrderItemId END AND
					order_items.FkReceiverDetailsId = CASE WHEN pFkReceiverDetailsId = 0 THEN order_items.FkReceiverDetailsId ELSE pFkReceiverDetailsId END AND
					order_items.FkProductId = CASE WHEN pFkProductId = 0 THEN order_items.FkProductId ELSE pFkProductId END
		ORDER BY order_items.PkOrderItemId;

END

