	PkOrderItemId	int(11) AI PK
	FkReceiverDetailsId	int(11)
	FkProductId	int(11)
	FkLuColorId	int(11)
	OutwardQty	int(11)
	FkUnitId	int(11)
	UnitPrice	decimal(10,2)
	TransactionDate	date
	IsActive	tinyint(1)
	CreatedDate	datetime
	CreatedBy	int(11)

---
prc_order_items_get:

CREATE DEFINER=`user`@`%` PROCEDURE `prc_order_items_get`(pAction INT, pLookUpId INT)
BEGIN
IF pAction = 0 THEN
		SELECT order_items.PkOrderItemId, order_items.FkReceiverDetailsId, order_items.FkProductId,lu_color_code.PkLuColorId,lu_color_code.ColorName, order_items.OutwardQty, order_items.FkUnitId, order_items.UnitPrice, order_items.TransactionDate, order_items.CreatedDate, order_items.CreatedBy, IFNULL(CretedUser.FullName,'') as CreateUserName, IFNULL(product_master.MaterialName,'') as MaterialName, IFNULL(product_master.MaterialCode,'') as MaterialCode, IFNULL(product_master.MaterialRate,0) as MaterialRate, IFNULL(lu_unit.UnitTitle,'') as UnitTitle, IFNULL(lu_unit.UnitCode,'') as UnitCode, IFNULL(receiver_details.ReceiverName,'') as ReceiverName,
					(CASE WHEN order_items.IsActive = 0 THEN 'InActive' ELSE 'Active' END) AS IsActive
		FROM order_items
			LEFT JOIN product_master ON product_master.PkProductId = order_items.FkProductId
			LEFT JOIN lu_unit ON lu_unit.PkUnitId = order_items.FkUnitId
			LEFT JOIN receiver_details ON receiver_details.PkReceiverDetailsId = order_items.FkReceiverDetailsId
			LEFT JOIN employee_master CretedUser ON CretedUser.EmployeeCode = order_items.CreatedBy
            LEFT JOIN lu_color_code ON order_items.FkLuColorId = lu_color_code.PkLuColorId
		ORDER BY order_items.PkOrderItemId;
	END IF;
	IF pAction = 1 THEN
		SELECT order_items.PkOrderItemId, order_items.FkReceiverDetailsId, order_items.FkProductId,lu_color_code.PkLuColorId,lu_color_code.ColorName, order_items.OutwardQty, order_items.FkUnitId, order_items.UnitPrice, order_items.TransactionDate, order_items.CreatedDate, order_items.CreatedBy, IFNULL(CretedUser.FullName,'') as CreateUserName, IFNULL(product_master.MaterialName,'') as MaterialName, IFNULL(product_master.MaterialCode,'') as MaterialCode, IFNULL(product_master.MaterialRate,0) as MaterialRate, IFNULL(lu_unit.UnitTitle,'') as UnitTitle, IFNULL(lu_unit.UnitCode,'') as UnitCode, IFNULL(receiver_details.ReceiverName,'') as ReceiverName,
					(CASE WHEN order_items.IsActive = 0 THEN 'InActive' ELSE 'Active' END) AS IsActive
		FROM order_items
			LEFT JOIN product_master ON product_master.PkProductId = order_items.FkProductId
			LEFT JOIN lu_unit ON lu_unit.PkUnitId = order_items.FkUnitId
			LEFT JOIN receiver_details ON receiver_details.PkReceiverDetailsId = order_items.FkReceiverDetailsId
			LEFT JOIN employee_master CretedUser ON CretedUser.EmployeeCode = order_items.CreatedBy
            LEFT JOIN lu_color_code ON order_items.FkLuColorId = lu_color_code.PkLuColorId
		WHERE order_items.PkOrderItemId = pLookUpId
		ORDER BY order_items.PkOrderItemId;
	END IF;
END

