prc_order_items_set:

CREATE DEFINER=`user`@`%` PROCEDURE `prc_order_items_set`(pPkOrderItemId INT,pFkReceiverDetailsId INT,pFkProductId INT, pFkLuColorId int, pOutwardQty INT,pFkUnitId INT,pUnitPrice DECIMAL(10,2),pCreatedBy INT,pIsActive INT)
BEGIN

    IF pPkOrderItemId = 0 THEN
        INSERT INTO order_items (FkReceiverDetailsId, FkProductId, FkLuColorId, OutwardQty, FkUnitId, UnitPrice, TransactionDate, IsActive, CreatedDate, CreatedBy)
        VALUES (pFkReceiverDetailsId, pFkProductId,pFkLuColorId, pOutwardQty, pFkUnitId, pUnitPrice, NOW(), pIsActive, NOW(), pCreatedBy);
    ELSE
        UPDATE order_items SET
            FkProductId = pFkProductId,FkLuColorId = pFkLuColorId, OutwardQty = pOutwardQty, FkUnitId = pFkUnitId,
            UnitPrice = pUnitPrice, IsActive = pIsActive
        WHERE PkOrderItemId = pPkOrderItemId;
    END IF;
END
