meta {
  name: Update Courier
  type: http
  seq: 4
}

put {
  url: {{baseUrl}}/courier-partners/{{createdCourierId}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "courierName": "Ecom Express Updated",
    "trackingUrlTemplate": "https://ecomexpress.in/track/awb/{AWB}"
  }
}

assert {
  res.status: eq 200
  res.body.success: isTruthy
  res.body.data.courierName: eq "Ecom Express Updated"
}
