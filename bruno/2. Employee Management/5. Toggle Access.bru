meta {
  name: Toggle Access
  type: http
  seq: 5
}

patch {
  url: {{baseUrl}}/employees/{{createdEmployeeId}}/toggle-access
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "allowLogin": false
  }
}

assert {
  res.status: eq 200
  res.body.success: isTruthy
  res.body.data.allowLogin: isFalsy
}
